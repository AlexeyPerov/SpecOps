{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpecOps",
  "version": "0.2.0",
  "identifier": "com.alexeyperov.specops",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SpecOps",
        "width": 800,
        "height": 1020,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "name": "Text Document",
        "description": "Text-based document",
        "role": "Editor",
        "mimeType": "text/plain",
        "ext": [
          "txt",
          "md",
          "markdown",
          "text",
          "log",
          "json",
          "yaml",
          "yml",
          "toml",
          "csv"
        ]
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
