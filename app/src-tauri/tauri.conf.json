{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpecOps",
  "version": "0.2.0",
  "identifier": "com.alexeyperov.specops",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SpecOps",
        "width": 800,
        "height": 1020,
        "dragDropEnabled": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 18 }
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost https://asset.localhost blob: data:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": ["$HOME/**/*", "$APPDATA/**/*"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/opencode"],
    "fileAssociations": [
      {
        "name": "Any File",
        "description": "Allows opening files dropped onto the app icon",
        "role": "Editor",
        "rank": "Alternate",
        "contentTypes": [
          "public.item",
          "public.content",
          "public.data",
          "public.plain-text",
          "public.text",
          "public.source-code"
        ]
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
